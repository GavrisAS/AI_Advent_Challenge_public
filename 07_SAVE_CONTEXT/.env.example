# Скопируйте файл в .env и подставьте свой ключ.
DEEPSEEK_API_KEY=your_api_key_here

# Можно переопределить модель. По умолчанию используется deepseek-v4-flash.
DEEPSEEK_MODEL=deepseek-v4-flash

# Опционально: путь к JSON-файлу с сохраняемым контекстом.
# Если не задано, используется .agent_context/messages.json
# AI_ADVENT_CONTEXT_FILE=.agent_context/messages.json
