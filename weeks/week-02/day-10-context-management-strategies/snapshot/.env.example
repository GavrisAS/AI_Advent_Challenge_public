# Скопируйте файл в .env и подставьте свой ключ.
DEEPSEEK_API_KEY=

# Можно переопределить модель. По умолчанию используется deepseek-v4-flash.
DEEPSEEK_MODEL=deepseek-v4-flash

# Опционально: URL DeepSeek-compatible Chat Completions API.
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Persistent context.
# AI_ADVENT_CONTEXT_FILE=.agent_context/messages.json
# AI_ADVENT_SUMMARY_FILE=.agent_context/summary.json
# AI_ADVENT_FACTS_FILE=.agent_context/facts.json
# AI_ADVENT_BRANCHES_FILE=.agent_context/branches.json
# AI_ADVENT_TOKEN_REPORT_FILE=.agent_context/token_reports.jsonl

# Day 10 context strategy: sliding_window, sticky_facts или branching.
CONTEXT_STRATEGY=sliding_window
RECENT_MESSAGES_LIMIT=6

# Day 9 summary memory сохранена, но для Day 10 comparison используйте off.
SUMMARY_MODE=off
SUMMARIZE_EVERY_MESSAGES=8
SUMMARY_MAX_TOKENS=600

# Лимит контекстного окна модели.
CONTEXT_WINDOW_TOKENS=1000000
WARN_CONTEXT_RATIO=0.80

# Политика при переполнении контекста:
# error          — не отправлять запрос, если локальная оценка превышает лимит
# no_trim        — отправить как есть и показать ошибку API, если провайдер её вернёт
# sliding_window — удалить старые сообщения, чтобы свежий запрос помещался в окно
CONTEXT_OVERFLOW_POLICY=error

# Цены намеренно не зашиты в код: подставьте актуальные тарифы провайдера вручную.
# Значения — стоимость 1M input/output токенов в USD.
INPUT_PRICE_PER_1M_TOKENS=0.14
OUTPUT_PRICE_PER_1M_TOKENS=0.28
